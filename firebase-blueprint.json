{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A player's high score entry for the leaderboard.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique ID of the player."
        },
        "displayName": {
          "type": "string",
          "description": "The name of the player."
        },
        "photoURL": {
          "type": "string",
          "description": "The player's profile picture URL."
        },
        "score": {
          "type": "integer",
          "description": "The highest score achieved by the player."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the score was last updated."
        }
      },
      "required": ["uid", "displayName", "score", "updatedAt"]
    }
  },
  "firestore": {
    "/leaderboard/{scoreId}": {
      "schema": "Score",
      "description": "Collection of global high scores."
    }
  }
}
