rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required) - The unique ID of the player
    //   - displayName: string (required) - The name of the player
    //   - photoURL: string (optional) - The player's profile picture URL
    //   - score: number (required) - The highest score achieved
    //   - updatedAt: timestamp (required) - Last update time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'displayName', 'score', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.score is number && data.score >= 0 &&
             data.updatedAt is timestamp;
    }

    match /leaderboard/{userId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Only the owner can create or update their own score
      allow create: if isOwner(userId) && isValidScore(request.resource.data);
      allow update: if isOwner(userId) && isValidScore(request.resource.data) && 
                      request.resource.data.score >= resource.data.score;
    }
  }
}
